# Database
DB_URL=jdbc:postgresql://localhost:5432/marketplace_db
DB_USERNAME=postgres
DB_PASSWORD=change_me
JPA_DDL_AUTO=update
SERVER_PORT=8080

# Test database, used by mvn test so integration tests do not write to marketplace_db
TEST_DB_URL=jdbc:postgresql://localhost:5432/marketplace_test_db
TEST_DB_USERNAME=postgres
TEST_DB_PASSWORD=change_me
TEST_JPA_DDL_AUTO=update

# Security
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_CORS_ALLOWED_ORIGIN_PATTERNS=
APP_SWAGGER_ENABLED=false
APP_ACTUATOR_EXPOSURE=health

# Local uploads 
APP_UPLOAD_BASE_DIR=backend/upload
APP_MULTIPART_MAX_FILE_SIZE=10MB
APP_MULTIPART_MAX_REQUEST_SIZE=10MB
APP_UPLOAD_MAX_AVATAR_SIZE_BYTES=3145728
APP_UPLOAD_MAX_PRODUCT_IMAGE_SIZE_BYTES=5242880
APP_UPLOAD_MAX_PRODUCT_IMAGE_PIXELS=20000000
APP_UPLOAD_MAX_STORE_IMAGE_SIZE_BYTES=5242880
APP_UPLOAD_MAX_CATEGORY_IMAGE_SIZE_BYTES=5242880
APP_UPLOAD_MAX_REVIEW_IMAGE_SIZE_BYTES=5242880
APP_UPLOAD_MAX_RETURN_EVIDENCE_SIZE_BYTES=5242880

# Seeder
APP_SEED_ENABLED=false
APP_SEED_GAP_ENABLED=false
APP_SEED_GAP_TARGET_COUNT=1000
APP_SEED_GAP_STYLES_PATH=backend/src/main/resources/product/styles.csv
APP_SEED_GAP_IMAGES_PATH=backend/src/main/resources/product/images.csv
APP_SEED_GAP_CLEAN_BEFORE_IMPORT=false
APP_SEED_GAP_REPORT_ENABLED=false
APP_SEED_GAP_REPORT_OUTPUT_DIR=backend/target/gap-coverage

# Chatbot
APP_CHATBOT_AI_FALLBACK_ENABLED=false
AZURE_BOT_AUTH_ENABLED=false
MicrosoftAppId=00000000-0000-0000-0000-000000000000
MicrosoftAppPassword=dummy-secret
MicrosoftAppTenantId=00000000-0000-0000-0000-000000000000
MicrosoftAppType=SingleTenant
BOT_DIRECT_LINE_SECRET=
BOT_DIRECT_LINE_TOKEN_ENDPOINT=https://directline.botframework.com/v3/directline/tokens/generate
BOT_DIRECT_LINE_CONVERSATION_ENDPOINT=https://directline.botframework.com/v3/directline/conversations

# Vision image search
APP_VISION_ENABLED=true
APP_VISION_BASE_URL=http://localhost:8001
APP_VISION_INTERNAL_SECRET=your_vision_secret
APP_VISION_CONNECT_TIMEOUT_MS=3000
APP_VISION_READ_TIMEOUT_MS=20000
APP_VISION_MAX_CANDIDATES=120
APP_VISION_MAX_UPLOAD_SIZE_BYTES=5242880
APP_VISION_RATE_LIMIT_ENABLED=true
APP_VISION_RATE_LIMIT_PER_MINUTE=6
APP_VISION_RATE_LIMIT_PER_HOUR=30
APP_TRUST_PROXY_HEADERS=false

# Promotion notifications
APP_PROMOTION_NOTIFICATION_TIMEZONE=Asia/Ho_Chi_Minh
APP_PROMOTION_DISPATCHER_DELAY_MS=15000
APP_PROMOTION_DISPATCHER_BATCH_SIZE=100
APP_PROMOTION_DISPATCHER_MAX_ATTEMPTS=8
APP_PROMOTION_DISPATCHER_BACKOFF_MINUTES=1,5,15,60
APP_PROMOTION_REMINDER_CRON=0 */10 * * * *

# VNPay
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/payment-result
VNPAY_IPN_URL=
VNPAY_EXPIRE_MINUTES=15
VNPAY_LOCALE=vn

# MoMo
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_CREATE_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_QUERY_URL=https://test-payment.momo.vn/v2/gateway/api/query
MOMO_RETURN_URL=http://localhost:5173/payment-result
MOMO_IPN_URL=
MOMO_REQUEST_TYPE=captureWallet
MOMO_LANG=vi
MOMO_AUTO_CAPTURE=true
